<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>FitTrend Store</display-name>
    <description>E-commerce per articoli di fitness e palestra — Progetto TSW</description>

    <!-- ================================================================
         WELCOME FILE
         index.jsp fa redirect immediato alla HomeServlet
         ================================================================ -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ================================================================
         RISORSA JNDI — DataSource MySQL
         Il nome deve corrispondere a quello in web/META-INF/context.xml
         ================================================================ -->
    <resource-ref>
        <description>MySQL DataSource per FitTrend Store</description>
        <res-ref-name>jdbc/fittrend</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

    <!-- ================================================================
         MAPPING SERVLET
         Tutte le Servlet del package control vengono mappate qui.
         Aggiungere ogni nuova Servlet in questa sezione.
         In alternativa è possibile usare @WebServlet sulle singole classi.
         ================================================================ -->

